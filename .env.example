# picoclaw-free-llm — API keys for all supported providers
#
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# Keys are loaded in this order (first match wins):
#   1. Real environment variable (export KEY=...)
#   2. .env in the project directory  ← this file
#   3. ~/.picoclaw-free-llm/.secrets
#
# .env is gitignored — never commit real keys.
# Leave unused providers blank; they will be skipped.

# ─── Truly Free (no credit card, rate-limited) ────────────────────────────────

# Groq — fastest inference available, all models free
# Limits: per-model RPM/RPD, resets daily. Easiest to start with.
# Keys:   https://console.groq.com/keys
GROQ_API_KEY=

# Google AI Studio (Gemini) — generous RPD (1500/day), 1M token context
# Limits: 4-dimensional (RPM/TPM/RPD/IPM), resets midnight PT
# Keys:   https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenRouter — routes to 50+ free models via a single key
# Free models detected via pricing.prompt == "0" or ":free" suffix
# Keys:   https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# Cerebras — extremely fast (hardware accelerated), free tier
# Limits: per-second RPS (not RPM), requires request spacing
# Keys:   https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# Mistral AI — limited free tier (2 RPM), good for occasional use
# Keys:   https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# Hugging Face Inference — warm models only, 300 calls/hour
# Note: cold-start 503s are normal; proxy will wait and retry
# Keys:   https://huggingface.co/settings/tokens
HF_API_KEY=

# ─── Credit-Based Free Tier (signup credits, then pay) ────────────────────────

# Together AI — $1 free credit on signup
# Keys:   https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# DeepSeek — free credits on signup, strong reasoning models (R1)
# Keys:   https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Cohere — 1000 req/month free forever (not per day — per month)
# Keys:   https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# NVIDIA NIM — free credits on signup, 40 RPM hard limit
# Keys:   https://build.nvidia.com/settings/api-key
NVIDIA_API_KEY=

# ─── Local (no key needed) ────────────────────────────────────────────────────

# Ollama — runs models locally, set enabled: true in config.yaml
# No key required; set base_url in config if port differs from 11434
# Install: https://ollama.com
