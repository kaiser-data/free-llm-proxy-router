# free-llm-proxy-router — API keys
#
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# Keys are loaded in this order (first match wins):
#   1. Real environment variable (export KEY=...)
#   2. .env in the project directory  ← this file
#   3. ~/.free-llm-proxy-router/.secrets
#
# .env is gitignored — never commit real keys.
# Leave unused providers blank; they will be skipped.
#
# All providers below are truly free with recharging rate limits —
# no one-time credits, no credit card required.

# Groq — fastest inference, all models free, limits reset daily
# Keys:   https://console.groq.com/keys
GROQ_API_KEY=

# Google AI Studio (Gemini) — 1500 req/day, 1M token context, resets midnight PT
# Keys:   https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenRouter — 50+ free models (pricing == "0"), always available
# Keys:   https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# GitHub Models — free with any GitHub account, limits reset per minute/day
# Keys:   https://github.com/settings/tokens  (any PAT works)
GITHUB_TOKEN=

# Cerebras — hardware-accelerated inference, free tier, limits reset
# Keys:   https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# Hugging Face Inference — 300 calls/hour (resets hourly), warm models only
# Keys:   https://huggingface.co/settings/tokens
HF_API_KEY=

# Mistral AI — 2 RPM free tier (resets), good for occasional use
# Keys:   https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# NVIDIA NIM — free credits that recharge monthly, 40 RPM, 200+ models
# Keys:   https://build.nvidia.com/settings/api-key
NVIDIA_API_KEY=

# Cohere — 1000 req/month free forever (resets monthly, no credit card)
# Keys:   https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# Ollama — local models, no key needed
# Set enabled: true in config.yaml and install from https://ollama.com
