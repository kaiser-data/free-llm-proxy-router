# picoclaw-free-llm API keys
# Copy this file to ~/.picoclaw-free-llm/.secrets (or .env in the project root)
# and fill in your keys. Lines starting with # are ignored.
#
# Key lookup order (first match wins):
#   1. Real environment variable (export KEY=...)
#   2. ~/.picoclaw-free-llm/.secrets  (or .env)
#   3. .secrets / .env in the project directory
#
# NEVER commit this file to git.

OPENROUTER_API_KEY=sk-or-...
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=AIza...
MISTRAL_API_KEY=...
CEREBRAS_API_KEY=...
TOGETHER_API_KEY=...
DEEPSEEK_API_KEY=...
COHERE_API_KEY=...
NVIDIA_API_KEY=nvapi-...
HF_API_KEY=hf_...
